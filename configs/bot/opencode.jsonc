{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": ["openai-compatible"],
  "provider": {
    "openai-compatible": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "{env:OPENAI_COMPATIBLE_BASE_URL}",
        "apiKey": "{env:OPENAI_COMPATIBLE_API_KEY}"
      },
      "models": {
        "deepseek/deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash"
        }
      }
    }
  },
  "model": "openai-compatible/deepseek/deepseek-v4-flash",
  "permission": {
    "write": "allow",
    "edit": "allow",
    "bash": "allow",
    "external_directory": {
      "/**": "allow"
    }
  },
  "default_agent": "default",
  "agent": {
    "default": {
      "mode": "primary",
      "description": "Telegram assistant that handles user requests, scheduling, and task execution. Use cron_add for reminders and scheduled tasks.",
      "prompt": "{file:./prompts/agent.md}",
      "permission": {
        "write": "allow",
        "edit": "allow",
        "bash": "allow",
        "task": "allow",
        "webfetch": "allow",
        "lsp": "allow",
        "skill": "allow",
        "question": "allow",
        "gateway_cron_add": "allow",
        "gateway_cron_list": "allow",
        "gateway_cron_delete": "allow",
        "gateway_cron_run": "allow"
      }
    }
  },
  "mcp": {
    "gateway": {
      "type": "remote",
      "url": "http://telegram-bot:8765/mcp",
      "enabled": true,
      "oauth": false,
      "headers": {
        "X-API-Key": "{env:MCP_SERVER_TOKEN}"
      }
    }
  }
}
