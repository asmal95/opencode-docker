{
  "$schema": "https://opencode.ai/schemas/config.json",
  "providers": {
    "anthropic": {
      "apiKey": "{env:ANTHROPIC_API_KEY}",
      "models": {
        "default": "claude-3-5-sonnet-20240620",
        "coding": "claude-3-5-sonnet-20240620"
      }
    },
    "openai": {
      "apiKey": "{env:OPENAI_API_KEY}",
      "models": {
        "default": "gpt-4o",
        "coding": "gpt-4o"
      }
    }
  },
  "permissions": {
    "write": "ask",
    "edit": "ask",
    "bash": "ask"
  },
  "tools": {
    "allowed": ["*"]
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  }
}