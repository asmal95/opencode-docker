# Multi-stage: use existing opencode-base, add Python MCP server
FROM asmal95/opencode-platform:latest AS opencode-base

# Base image already has python3 + python3-venv installed.
# It also switches to non-root user 'coder', so create venv in home dir.
RUN python3 -m venv /home/coder/mcp-venv
ENV PATH="/home/coder/mcp-venv/bin:$PATH"

# Install Python MCP server dependencies
COPY sidecars/gitlab-mcp/requirements.txt /tmp/requirements.txt
RUN python3 -m pip install --no-cache-dir -r /tmp/requirements.txt

# Copy MCP server source
COPY sidecars/gitlab-mcp/ /opt/gitlab-mcp/

# Copy OpenCode config
COPY configs/gitlab/ /opt/opencode-config/

# Default: run opencode in 'run' mode (one-shot)
ENTRYPOINT ["opencode"]
CMD ["run"]
